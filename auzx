    Instance.new("UICorner", ToggleTrack).CornerRadius = UDim.new(1, 0)

    local SliderNode = Instance.new("Frame", ToggleTrack)
    SliderNode.Size = UDim2.new(0, 18, 0, 18)
    SliderNode.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    SliderNode.BorderSizePixel = 0
    Instance.new("UICorner", SliderNode).CornerRadius = UDim.new(1, 0)

    local function UpdateState(instant)
        local targetPos = state and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
        local targetColor = state and getDarkAccent(currentAccent) or Color3.fromRGB(50, 50, 55)
        TitleLbl.Text = titleText .. (state and " [ON]" or " [OFF]")
        TitleLbl.TextColor3 = state and Color3.fromRGB(240, 240, 245) or Color3.fromRGB(180, 180, 185)
