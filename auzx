local function UpdateAccentColor(newColor)
    currentAccent = newColor
    local darkAccent = getDarkAccent(currentAccent)
    local bgTint = getBgTint(currentAccent)

    Logo.BackgroundColor3 = currentAccent
    Title.TextColor3 = currentAccent
    
    for name, data in pairs(tabs) do
        if name == activeTabName then
            data.Button.BackgroundColor3 = bgTint
            data.Button.TextColor3 = currentAccent
            data.Stroke.Transparency = 0
            data.Stroke.Color = darkAccent
        else
            data.Button.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
            data.Button.TextColor3 = Color3.fromRGB(140, 140, 145)
            data.Stroke.Transparency = 1
        end
    end
    
    SectionHeader.TextColor3 = currentAccent
    SettingsHeader.TextColor3 = currentAccent

    for _, row in pairs(RowContainer:GetChildren()) do
        if row:IsA("Frame") then
            local track = row:FindFirstChildWhichIsA("TextButton")
            if track then
                local titleTxt = row:FindFirstChildWhichIsA("TextLabel")
                if titleTxt and string.find(titleTxt.Text, "[ON]") then
                    track.BackgroundColor3 = darkAccent
                end
            end
        end
    end

    for _, swatch in pairs(SwatchContainer:GetChildren()) do
        if swatch:IsA("TextButton") then
            local sStroke = swatch:FindFirstChildWhichIsA("UIStroke")
            if sStroke then
                if swatch.BackgroundColor3 == currentAccent then
                    sStroke.Transparency = 0
                    sStroke.Color = Color3.fromRGB(255, 255, 255)
                else
                    sStroke.Transparency = 1
                end
            end
        end
    end
    
    ESP_Config.BoxColor = newColor
    ESP_Config.FillColor = newColor
    ESP_Config.SkeletonColor = newColor
    ESP_Config.ChamsColor = newColor
    ESP_Config.NamesColor = newColor
end

