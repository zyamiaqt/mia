            TweenService:Create(SliderNode, TweenInfo.new(0.2), {Position = targetPos}):Play()
            TweenService:Create(ToggleTrack, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        end
    end

    ToggleTrack.MouseButton1Click:Connect(function()
        state = not state
        UpdateState(false)
        callback(state)
    end)
    UpdateState(true)
end

