local function SwitchTab(tabName)
    activeTabName = tabName
    for name, data in pairs(tabs) do
        if name == tabName then
            data.Button.BackgroundColor3 = getBgTint(currentAccent)
            data.Button.TextColor3 = currentAccent
            data.Stroke.Transparency = 0
            data.Stroke.Color = getDarkAccent(currentAccent)
        else
            data.Button.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
            data.Button.TextColor3 = Color3.fromRGB(140, 140, 145)
            data.Stroke.Transparency = 1
        end
    end

    if tabName == "Main" then
        ContentPanel.Visible = true
        SettingsPanel.Visible = false
    else
        ContentPanel.Visible = false
        SettingsPanel.Visible = true
    end
end

