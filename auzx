local currentAccent = Color3.fromRGB(235, 185, 75)

local function getDarkAccent(color)
    return Color3.new(color.R * 0.65, color.G * 0.65, color.B * 0.65)
end

local function getBgTint(color)
    return Color3.fromRGB(
        math.clamp(15 + (color.R * 25), 0, 255),
        math.clamp(15 + (color.G * 25), 0, 255),
        math.clamp(17 + (color.B * 25), 0, 255)
    )
end

