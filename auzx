local isResizing = false
local resizeStartPos = Vector3.new(0, 0, 0)
local resizeStartSize = UDim2.new()

local MIN_WIDTH, MAX_WIDTH = 450, 1200
local MIN_HEIGHT, MAX_HEIGHT = 350, 900

ResizeGrip.InputBegan:Connect(function(input)
    if not isOpen then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing = true
        resizeStartPos = input.Position
        resizeStartSize = MainFrame.Size
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isResizing then
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local deltaX = input.Position.X - resizeStartPos.X
            local deltaY = input.Position.Y - resizeStartPos.Y
            local newWidth = math.clamp(resizeStartSize.X.Offset + deltaX, MIN_WIDTH, MAX_WIDTH)
            local newHeight = math.clamp(resizeStartSize.Y.Offset + deltaY, MIN_HEIGHT, MAX_HEIGHT)
            MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing = false
    end
end)

local isOpen = true
local savedSize = MainFrame.Size
local isAnimating = false

local function PreMinimize()
    TabLayout.Parent = nil
    RowLayout.Parent = nil
end

local function PostRestore()
    TabLayout.Parent = TabContainer
    RowLayout.Parent = RowContainer
end

local function ToggleUI()
    if isAnimating then return end
    isOpen = not isOpen
    isAnimating = true
    
    if isOpen then
        MainFrame.Visible = true
        ResizeGrip.Visible = true
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        TabContainer.CanvasPosition = Vector2.new(0, 0)
        RowContainer.CanvasPosition = Vector2.new(0, 0)
        
        local restoreTween = TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = savedSize})
        restoreTween:Play()
        restoreTween.Completed:Connect(function()
            PostRestore()
            isAnimating = false
        end)
    else
        savedSize = MainFrame.Size
        isResizing = false
        PreMinimize()
        
        local minimizeTween = TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
        minimizeTween:Play()
        minimizeTween.Completed:Connect(function()
            isAnimating = false
            if not isOpen then
                MainFrame.Visible = false
                ResizeGrip.Visible = false
            end
        end)
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then ToggleUI() end
end)

