    ToggleTrack.Size = UDim2.new(0, 44, 0, 24)
    ToggleTrack.Position = UDim2.new(1, -60, 0.5, -12)
    ToggleTrack.Text = ""
    ToggleTrack.BorderSizePixel = 0
