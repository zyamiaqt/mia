    local function UpdateState(instant)
        local targetPos = state and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
        local targetColor = state and getDarkAccent(currentAccent) or Color3.fromRGB(50, 50, 55)
