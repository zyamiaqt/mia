            data.Button.TextColor3 = Color3.fromRGB(140, 140, 145)
            data.Stroke.Transparency = 1
        end
    end

    if tabName == "Main" then
        ContentPanel.Visible = true
        SettingsPanel.Visible = false
    else
        ContentPanel.Visible = false
        SettingsPanel.Visible = true
    end
end

