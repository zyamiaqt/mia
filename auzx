-- ==========================================
-- RESIZE LOGIC
-- ==========================================
local isResizing = false
local resizeStartPos = Vector3.new(0, 0, 0)
local resizeStartSize = UDim2.new()

local MIN_WIDTH, MAX_WIDTH = 450, 1200
local MIN_HEIGHT, MAX_HEIGHT = 350, 900

ResizeGrip.InputBegan:Connect(function(input)
    if not isOpen then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing = true
        resizeStartPos = input.Position
        resizeStartSize = MainFrame.Size
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isResizing then
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local deltaX = input.Position.X - resizeStartPos.X
            local deltaY = input.Position.Y - resizeStartPos.Y
            
            local newWidth = math.clamp(resizeStartSize.X.Offset + deltaX, MIN_WIDTH, MAX_WIDTH)
            local newHeight = math.clamp(resizeStartSize.Y.Offset + deltaY, MIN_HEIGHT, MAX_HEIGHT)
            
            MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isResizing = false
    end
end)

-- ==========================================
-- TOGGLE LOGIC (INSERT KEY + MINIMIZE BUTTON)
-- ==========================================
local isOpen = true
local savedSize = MainFrame.Size
local isAnimating = false

-- CRITICAL FIX: ScrollingFrames with AutomaticCanvasSize fight against tweening to 0,0.
-- We must temporarily disable auto-sizing and crush the canvas before minimizing.
local function PreMinimize()
    TabContainer.AutomaticCanvasSize = Enum.AutomaticSize.None
    TabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    RowContainer.AutomaticCanvasSize = Enum.AutomaticSize.None
    RowContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
end

-- Re-enable auto canvas sizing so scrolling works normally again after restoring
local function PostRestore()
    TabContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
    RowContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
end

local function ToggleUI()
    if isAnimating then return end
    isOpen = not isOpen
    isAnimating = true
    
    if isOpen then
        MainFrame.Visible = true
        ResizeGrip.Visible = true
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        
        TabContainer.CanvasPosition = Vector2.new(0, 0)
        RowContainer.CanvasPosition = Vector2.new(0, 0)
        
        local restoreTween = TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = savedSize})
        restoreTween:Play()
        restoreTween.Completed:Connect(function()
            PostRestore() -- Turn scrolling back on safely
            isAnimating = false
        end)
    else
        savedSize = MainFrame.Size
        isResizing = false
        
        PreMinimize() -- Break scroll lock before tweening
        
        local minimizeTween = TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
        minimizeTween:Play()
        minimizeTween.Completed:Connect(function()
            isAnimating = false
            if not isOpen then
                MainFrame.Visible = false
                ResizeGrip.Visible = false
            end
        end)
    end
end

